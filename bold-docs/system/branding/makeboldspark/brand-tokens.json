{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": {
      "public": "Make Bold Spark",
      "technical": "MakeBoldSpark"
    },
    "tagline": {
      "short": "Practical software sparks, built boldly."
    }
  },
  "color": {
    "ink": {
      "$type": "color",
      "$value": "#040605"
    },
    "spark": {
      "$type": "color",
      "$value": "#E94B1B"
    },
    "ember": {
      "$type": "color",
      "$value": "#982407"
    },
    "paper": {
      "$type": "color",
      "$value": "#F7F4EF"
    },
    "cream": {
      "$type": "color",
      "$value": "#EEE8DF"
    },
    "smoke": {
      "$type": "color",
      "$value": "#787878"
    },
    "steel": {
      "$type": "color",
      "$value": "#2F3A3D"
    },
    "mint": {
      "$type": "color",
      "$value": "#3FBFA8"
    },
    "gold": {
      "$type": "color",
      "$value": "#F2B84B"
    },
    "white": {
      "$type": "color",
      "$value": "#FFFFFF"
    }
  },
  "font": {
    "family": {
      "display": {
        "$type": "fontFamily",
        "$value": "Inter Tight"
      },
      "fallback": {
        "$type": "fontFamily",
        "$value": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif"
      }
    },
    "weight": {
      "regular": {
        "$type": "fontWeight",
        "$value": 400
      },
      "medium": {
        "$type": "fontWeight",
        "$value": 550
      },
      "bold": {
        "$type": "fontWeight",
        "$value": 800
      },
      "black": {
        "$type": "fontWeight",
        "$value": 900
      }
    }
  },
  "radius": {
    "control": {
      "$type": "dimension",
      "$value": "8px"
    },
    "icon": {
      "$type": "dimension",
      "$value": "28px"
    }
  },
  "shadow": {
    "raised": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(4, 6, 5, 0.14)",
        "offsetX": "0px",
        "offsetY": "18px",
        "blur": "48px",
        "spread": "0px"
      }
    }
  }
}

